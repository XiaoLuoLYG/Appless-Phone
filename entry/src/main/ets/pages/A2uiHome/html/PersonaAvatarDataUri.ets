const PERSONA_AVATAR_DEFAULT: string = 'data:image/svg+xml;base64,';
const PERSONA_AVATAR_FOOD: string = 'data:image/svg+xml;base64,';
const PERSONA_AVATAR_TRAVEL: string = 'data:image/svg+xml;base64,';
const PERSONA_AVATAR_WORK: string = 'data:image/svg+xml;base64,';
const PERSONA_AVATAR_ENTERTAINMENT: string = 'data:image/svg+xml;base64,';
const PERSONA_AVATAR_GAME: string = 'data:image/svg+xml;base64,';
const PERSONA_AVATAR_SHOPPING: string = 'data:image/svg+xml;base64,';

export function personaAvatarDataUri(avatarKey: string): string {
  if (avatarKey === 'food') {
    return PERSONA_AVATAR_FOOD;
  }
  if (avatarKey === 'travel') {
    return PERSONA_AVATAR_TRAVEL;
  }
  if (avatarKey === 'work') {
    return PERSONA_AVATAR_WORK;
  }
  if (avatarKey === 'entertainment') {
    return PERSONA_AVATAR_ENTERTAINMENT;
  }
  if (avatarKey === 'game') {
    return PERSONA_AVATAR_GAME;
  }
  if (avatarKey === 'shopping') {
    return PERSONA_AVATAR_SHOPPING;
  }
  return PERSONA_AVATAR_DEFAULT;
}
